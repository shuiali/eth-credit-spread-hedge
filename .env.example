# Non-secret runtime defaults. Never commit private exchange credentials.
ETH_HEDGE_ENVIRONMENT=LOCAL_EXACT
ETH_HEDGE_LEVEL_COUNT=1
ETH_HEDGE_STOP_MODE=ENTRY_PERCENT
ETH_HEDGE_ENTRY_STOP_RATE=0.0015
ETH_HEDGE_RECOVERY_MODE=FULL_NEXT_TP
ETH_HEDGE_LOCK_POLICY=UNHEDGED
ETH_HEDGE_RECOVERY_TP_COUNT=3
ETH_HEDGE_BASELINE_BUFFER_USD=0
ETH_HEDGE_RECOVERY_BUFFER_USD=0
ETH_HEDGE_ENTRY_FEE_RATE=0
ETH_HEDGE_TP_FEE_RATE=0
ETH_HEDGE_STOP_FEE_RATE=0
ETH_HEDGE_EXPECTED_ENTRY_SLIPPAGE_BPS=0
ETH_HEDGE_EXPECTED_TP_SLIPPAGE_BPS=0
ETH_HEDGE_EXPECTED_STOP_SLIPPAGE_BPS=0
# Signed funding P&L: positive is income, negative is cost.
ETH_HEDGE_EXPECTED_FUNDING_TO_TP_USD_PER_ETH=0
ETH_HEDGE_EXPECTED_FUNDING_TO_STOP_USD_PER_ETH=0
ETH_HEDGE_SPREAD_COST_ENTRY_BPS=0
ETH_HEDGE_SPREAD_COST_TP_BPS=0
ETH_HEDGE_SPREAD_COST_STOP_BPS=0
ETH_HEDGE_TRIGGER_PRICE_SOURCE=LAST_TRADE

# Bybit demo credentials. Keep real values only in the ignored .env file.
BYBIT_API_KEY_DEMO=
BYBIT_API_SECRET_DEMO=

# Use separately permissioned keys for each mainnet environment.
BYBIT_API_KEY_SHADOW_MAINNET=
BYBIT_API_SECRET_SHADOW_MAINNET=
BYBIT_API_KEY_PRODUCTION_PILOT=
BYBIT_API_SECRET_PRODUCTION_PILOT=
BYBIT_API_KEY_PRODUCTION=
BYBIT_API_SECRET_PRODUCTION=
