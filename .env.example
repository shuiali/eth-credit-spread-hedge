# Non-secret runtime defaults. Never commit private exchange credentials.
ETH_HEDGE_ENVIRONMENT=backtest
ETH_HEDGE_LEVEL_COUNT=1
ETH_HEDGE_STOP_RATE=0.0015
ETH_HEDGE_RECOVERY_MODE=FULL_NEXT_TP
ETH_HEDGE_LOCK_POLICY=UNHEDGED
ETH_HEDGE_RECOVERY_TP_COUNT=3
ETH_HEDGE_TRIGGER_PRICE_SOURCE=LAST_TRADE

# Bybit demo credentials. Keep real values only in the ignored .env file.
BYBIT_API_KEY_DEMO=
BYBIT_API_SECRET_DEMO=
